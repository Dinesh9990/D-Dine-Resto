<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>D Dine Resto</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
</head>
<body>

    <%- include("../includes/navbar.ejs")  %>
    
    <div class="container">
        <%- body %>
    </div>

    
    <% if (typeof showCart === 'undefined' || showCart) { %>
  <%- include("../includes/viewCart.ejs") %>
<% } %>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/addButton.js"></script>
    <script src="/js/handleDineInDelivery.js"></script>

    <% if (typeof orderType !== 'undefined' && orderType === 'dineIn') { %>
  <%- include("../includes/orderStatusBar.ejs") %>
<% } else if (typeof orderType !== 'undefined' && orderType === 'delivery') { %>
  <%- include("../includes/deliveryStatusBar.ejs") %>
<% } %>


<script src="/js/refresh.js"></script>
</body>
</html>